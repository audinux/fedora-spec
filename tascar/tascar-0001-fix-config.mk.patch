From a2a7175c246c2ad4b6563ad33ce9dcc32427fd7b Mon Sep 17 00:00:00 2001
From: Yann Collette <yc@example.com>
Date: Sat, 18 Jul 2026 15:48:12 +0200
Subject: [PATCH] fix config

---
 config.mk | 13 +------------
 1 file changed, 1 insertion(+), 12 deletions(-)

diff --git a/config.mk b/config.mk
index d4c3cc6..9e560c6 100644
--- a/config.mk
+++ b/config.mk
@@ -21,8 +21,6 @@ ifeq "x$(ARCH)" "xx86_64"
   endif
 endif
 
-CXXFLAGS += -Wall -Wextra -Wdeprecated-declarations -Wno-psabi -std=c++17 -pthread	\
--ggdb -fno-finite-math-only -Wno-psabi
 # -Wconversion
 # -Werror
 
@@ -33,22 +31,14 @@ UNAME_S := $(shell uname -s)
 ifeq ($(UNAME_S),Linux)
   DLLEXT=.so
   EXTERNALS +=  alsa
-  CXXFLAGS += -fext-numeric-literals
 else
   DLLEXT=.dylib
 endif
 endif
 
 
-ifeq "$(ARCH)" "x86_64"
-  CXXFLAGS += -msse -msse2 -mfpmath=sse
-  ifneq "$(UNAME_S)" "Darwin"
-    CXXFLAGS += -ffast-math
-  endif
-endif
-
 CPPFLAGS += -std=c++17
-PREFIX ?= /usr/local
+PREFIX ?= /usr/
 
 # Development builds derive FULLVERSION from Git metadata so local builds
 # include the commit count, commit hash and dirty state. Release/package builds
@@ -90,7 +80,6 @@ SOURCE_DIR = src
 export VERSION
 export SOURCE_DIR
 export BUILD_DIR
-export CXXFLAGS
 export HAS_LSL
 export HAS_OPENMHA
 export HAS_OPENCV2
-- 
2.55.0

